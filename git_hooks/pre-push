#!/bin/sh

set -eux

# Unset Node debugger environment variables to prevent interference with git hooks
unset NODE_OPTIONS
unset VSCODE_INSPECTOR_OPTIONS

npm run --silent ci:check

npx playwright test --config=playwright.s3.config.ts unity-builds.s3.spec.ts --reporter=line
npx playwright test --config=playwright.s3.config.ts recorder-sync.s3.spec.ts || echo "S3 sync skipped or failed (non-blocking)."

if [ -f .vercel/project.json ]; then
	npm run --silent vercel:pull
	npm run --silent vercel:build
else
	echo "Skipping Vercel build: project is not linked yet."
fi