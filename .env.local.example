NEXT_PUBLIC_RECORDER_TEST_MODE=true
NEXT_PUBLIC_RECORDER_UPLOAD_PATH=/api/recording-upload
NEXT_PUBLIC_UNITY_GAME_TITLE=Mock Unity Game
NEXT_PUBLIC_APP_URL=http://localhost:3000
AWS_ACCESS_KEY_ID=local-only-example
AWS_SECRET_ACCESS_KEY=local-only-example
AWS_REGION=us-east-1
AWS_S3_BUCKET=local-only-example
AWS_S3_RECORDINGS_PREFIX=recordings
# optional: If endpoint is undefined, client infers from AWS_REGION
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_PUBLIC_BASE_URL=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=local-only-example
NEXT_PUBLIC_POSTHOG_HOST=/ingest
NEXT_PUBLIC_RECORDER_VERBOSE=true
NEXT_PUBLIC_AUDIO_SILENT_DB=-50
NEXT_PUBLIC_AUDIO_QUIET_DB=-35
NEXT_PUBLIC_AUDIO_METER_SHOW_AFTER_S=10
NEXT_PUBLIC_UNITY_BUILDS_CONFIG_URL=/unity-builds-config.json
